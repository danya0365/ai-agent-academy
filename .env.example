# ฐานข้อมูล — dev ใช้ไฟล์ local ได้เลย; prod เปลี่ยนเป็น URL ของ Turso (libsql://...)
DATABASE_URL=file:./local.db
# ว่างไว้ตอน dev; ใส่ token ตอนใช้ Turso
DATABASE_AUTH_TOKEN=

# สร้างด้วย: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (สร้างที่ https://console.cloud.google.com/apis/credentials)
# redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google Search Console site verification code (สำหรับ OAuth brand verification)
# ได้จาก https://search.google.com/search-console → property "ai-agent-academy.easy-ai.online"
GOOGLE_SITE_VERIFICATION=

# โฟลเดอร์เก็บสลิป (local disk) — prod บน serverless ต้องเปลี่ยนเป็น S3/object storage
UPLOAD_DIR=./uploads

# ข้อมูลรับชำระเงิน (แสดงในหน้าจ่ายเงิน)
BANK_NAME=กสิกรไทย
BANK_ACCOUNT_NUMBER=123-4-56789-0
BANK_ACCOUNT_NAME=ชื่อบัญชีของร้าน
# เบอร์พร้อมเพย์หรือเลขบัตรประชาชน (เว้นว่างได้ถ้าไม่ใช้ QR)
PROMPTPAY_ID=0812345678

# บัญชีแอดมินเริ่มต้น (ใช้ตอน seed ระดับ initial)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin1234
ADMIN_NAME=ผู้ดูแลระบบ

# อนุญาตให้ seed mock ลง DB remote (Turso) — ปกติไม่ต้องตั้ง
# mock เป็นข้อมูลปลอมสำหรับ dev เท่านั้น ปกติจะถูกปฏิเสธถ้า DATABASE_URL ไม่ใช่ file:
# ตั้ง = 1 เฉพาะกรณีตั้งใจจริง
# ALLOW_MOCK_SEED=1

# ── ตรวจสลิปอัตโนมัติ (auto-approve) ──
# ว่าง = ปิด (แอดมินตรวจมือ) | easyslip | slipok | mock (สำหรับทดสอบ)
SLIP_VERIFY_PROVIDER=
SLIP_VERIFY_API_KEY=
# (เฉพาะ provider=mock เพื่อทดสอบ) ยอด/ref ที่จะให้คืน
# SLIP_VERIFY_MOCK_AMOUNT=1990
# SLIP_VERIFY_MOCK_REF=

# ── แจ้งเตือน LINE OA (Messaging API push; LINE Notify ปิดบริการแล้ว) ──
# channel access token ของ LINE OA + userId/groupId ปลายทางที่จะส่งเข้า
LINE_CHANNEL_ACCESS_TOKEN=
LINE_ADMIN_TARGET_ID=
# ลิงก์เพิ่มเพื่อน LINE OA — ใช้ทั้งแจ้งเตือนและปุ่มติดตามในกล่องสนับสนุน (หน้า "ไขความลับ")
NEXT_PUBLIC_LINE_OA_ADD_URL=

# ── รายได้/สนับสนุน dev (หน้า "ไขความลับ" /tips) ──
# เว้นว่างได้ทุกตัว — ช่องไหนไม่ตั้ง จะถูกซ่อน/แสดง placeholder อัตโนมัติ ไม่ทำให้หน้าพัง
# หมายเหตุ: กล่องสนับสนุนใช้ PROMPTPAY_ID (ด้านบน) และ NEXT_PUBLIC_LINE_OA_ADD_URL ซ้ำด้วย
# ลิงก์ร้าน Shopee หลัก (ออปชัน) — โชว์เป็นปุ่ม "ไปที่ร้าน" บนหน้า /shop
# ส่วนสินค้าที่แนะนำจริง ๆ อยู่ใน lib/shopee-products.generated.ts (เขียนอัตโนมัติ)
NEXT_PUBLIC_SHOPEE_AFFILIATE_URL=
# Shopee Product Feed (CSV) — ใช้โดย scripts/fetch-shopee-products.ts (npm run shopee:fetch)
# คัดสินค้าขายดีมาอัปเดต lib/shopee-products.generated.ts อัตโนมัติ (ฟีดอัพเดทเองทุกวัน)
# เอา URL จาก: affiliate.shopee.co.th → รูป → รายการ feed สินค้า → "ดูลิงก์" → คัดลอก
# (มี token ส่วนตัว → server-only ห้ามขึ้นต้น NEXT_PUBLIC_ และห้าม commit ค่าจริง)
SHOPEE_FEED_URL=
# Google AdSense — ใส่ตอนบัญชีผ่านการอนุมัติแล้ว (ก่อนหน้านั้นจะเห็น placeholder "พื้นที่โฆษณา")
# ⚠️ นโยบาย AdSense: ห้ามชวน/บังคับให้กดโฆษณา ใช้แบบแสดงผลตามธรรมชาติเท่านั้น
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT_TIPS=

# Cloudflare R2 — object storage for uploaded payment slips.
#   Local dev: leave UNSET → slips fall back to local disk (./uploads/slips).
#   Production (Vercel): set all four. Vercel's filesystem is ephemeral, so the
#   local fallback CANNOT be used there — uploads need R2.
# Create a bucket + an R2 API token (Object Read & Write) in the Cloudflare
# dashboard. The bucket stays PRIVATE; slips are served through the auth-gated
# /api/slips route, never a public URL.
# R2_ACCOUNT_ID="<cloudflare account id>"
# R2_ACCESS_KEY_ID="<r2 access key id>"
# R2_SECRET_ACCESS_KEY="<r2 secret access key>"
# R2_BUCKET="<bucket name>"
# R2_ENDPOINT (OPTIONAL) — override the endpoint; defaults to
#   https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ENDPOINT=""
