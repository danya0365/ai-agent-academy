{
  "name": "ai-agent-academy",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "tsx db/migrate.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "release:patch": "npm version patch -m \"chore(release): v%s\"",
    "release:minor": "npm version minor -m \"chore(release): v%s\"",
    "release:major": "npm version major -m \"chore(release): v%s\"",
    "version": "git add CHANGELOG.md",
    "db:generate": "drizzle-kit generate",
    "db:check": "tsx db/check-migrations.ts",
    "db:check:all": "tsx db/check-migrations.ts --all",
    "db:selftest": "tsx db/selftest-migrate.ts",
    "db:migrate": "RUN_MIGRATE=1 tsx db/migrate.ts",
    "db:migrate:prod": "RUN_MIGRATE=1 ENV_FILE=.env.local.production tsx db/migrate.ts",
    "db:baseline:prod": "ENV_FILE=.env.local.production tsx db/baseline.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx db/seed/index.ts initial starter",
    "db:seed:initial": "tsx db/seed/index.ts initial",
    "db:seed:starter": "tsx db/seed/index.ts starter",
    "db:seed:mock": "tsx db/seed/index.ts mock",
    "db:seed:all": "tsx db/seed/index.ts initial starter mock",
    "db:seed:prod": "ENV_FILE=.env.local.production tsx db/seed/index.ts initial starter",
    "shopee:fetch": "tsx scripts/fetch-shopee-products.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1070.0",
    "@libsql/client": "^0.17.3",
    "better-auth": "^1.6.18",
    "browser-image-compression": "^2.0.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "promptpay-qr": "^0.5.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "csv-parse": "^7.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "packageManager": "pnpm@9.15.0+sha512.76e2379760a4328ec4415815bcd6628dee727af3779aaa4c914e3944156c4299921a89f976381ee107d41f12cfa4b66681ca9c718f0668fa0831ed4c6d8ba56c"
}
